# SAP Identity Authentication Service (IAS)
VITE_IAS_TENANT_URL=https://<tenant>.accounts.ondemand.com
VITE_IAS_CLIENT_ID=<oauth2-client-id-from-ias-console>

# API Gateway base URL (Integration Suite API Management proxy)
VITE_API_BASE_URL=https://<apim-host>/tpapi/v1

# App base URL (used for OIDC redirect_uri)
VITE_APP_BASE_URL=http://localhost:5173
