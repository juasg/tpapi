{
  "name": "TPAPI_GetInvoice",
  "description": "Reads a single billing document from S/4HANA API_BILLING_DOCUMENT_SRV. Used as authoritative source (Snowflake holds list; S/4 holds detail).",
  "trigger": {
    "type": "HTTPReceiver",
    "endpoint": "/tpapi/internal/invoices/{id}",
    "method": "GET",
    "authentication": "ClientCertificate"
  },
  "steps": [
    {
      "step": 1,
      "type": "Groovy",
      "script": "buildBillingDocUrl.groovy",
      "description": "Build OData URL: /BillingDocument('{id}')?$expand=to_Item"
    },
    {
      "step": 2,
      "type": "ODataChannelSender",
      "receiverSystem": "S4HANA_Receiver",
      "serviceUrl": "/sap/opu/odata/sap/API_BILLING_DOCUMENT_SRV",
      "httpMethod": "GET",
      "authentication": "BasicAuthentication"
    },
    {
      "step": 3,
      "type": "MessageMapping",
      "mappingResource": "mm_BillingDoc_to_TPAPIInvoice",
      "description": "Map S/4 BillingDocument to TPAPI Invoice response schema"
    },
    {
      "step": 4,
      "type": "JSONConverter"
    }
  ],
  "receiverSystems": {
    "S4HANA_Receiver": {
      "type": "HTTP",
      "host": "${parameter.S4_HOST}",
      "port": 443,
      "proxyType": "OnPremise",
      "cloudConnectorLocationId": "${parameter.CC_LOCATION_ID}"
    }
  }
}
