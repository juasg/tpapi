{
  "name": "TPAPI_CreateSalesOrder",
  "description": "Receives POST /orders payload from API Management, transforms to S/4HANA OData A_SalesOrder, and returns the created order ID.",
  "trigger": {
    "type": "HTTPReceiver",
    "endpoint": "/tpapi/internal/orders",
    "method": "POST",
    "authentication": "ClientCertificate"
  },
  "steps": [
    {
      "step": 1,
      "type": "JSONToXMLConverter",
      "description": "Convert incoming JSON payload to XML for processing"
    },
    {
      "step": 2,
      "type": "MessageMapping",
      "mappingResource": "mm_CreateOrder_to_S4SalesOrder",
      "description": "Map TPAPI order structure to A_SalesOrder OData v4 format",
      "sourceStructure": {
        "OrderItems": "$.items[*]",
        "DeliveryDate": "$.deliveryDate",
        "CustomerReference": "$.notes"
      },
      "targetStructure": {
        "SoldToParty": "${header.X-Customer-Id}",
        "SalesOrderType": "TA",
        "RequestedDeliveryDate": "${source.DeliveryDate}",
        "to_Item": "${source.OrderItems}"
      }
    },
    {
      "step": 3,
      "type": "ODataChannelSender",
      "description": "POST to S/4HANA API_SALES_ORDER_SRV",
      "receiverSystem": "S4HANA_Receiver",
      "serviceUrl": "/sap/opu/odata4/sap/api_sales_order/srvd_a2x/sap/salesorder/0001/SalesOrder",
      "httpMethod": "POST",
      "contentType": "application/json",
      "authentication": "BasicAuthentication"
    },
    {
      "step": 4,
      "type": "Groovy",
      "script": "extractOrderId.groovy",
      "description": "Extract created SalesOrder ID from S/4 response"
    },
    {
      "step": 5,
      "type": "JSONConverter",
      "description": "Return {orderId, orderNumber, status: SUBMITTED} to API Management"
    }
  ],
  "errorHandling": {
    "type": "ErrorEndProcess",
    "returnHttpStatus": 502,
    "logToCloudLogging": true
  },
  "receiverSystems": {
    "S4HANA_Receiver": {
      "type": "HTTP",
      "host": "${parameter.S4_HOST}",
      "port": 443,
      "proxyType": "OnPremise",
      "cloudConnectorLocationId": "${parameter.CC_LOCATION_ID}"
    }
  }
}
